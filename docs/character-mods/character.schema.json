{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://firemio.local/schemas/character-mod-v1.json",
  "title": "MioMail Character MOD v1",
  "type": "object",
  "allOf": [
    {
      "required": ["schemaVersion", "id", "name", "version", "author", "behaviorProfile", "renderer", "source"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{2,63}$" },
        "name": { "type": "string", "minLength": 1, "maxLength": 80 },
        "version": { "type": "string", "minLength": 1, "maxLength": 32 },
        "author": { "type": "string", "minLength": 1, "maxLength": 80 },
        "description": { "type": "string", "maxLength": 300, "default": "" },
        "license": { "type": "string", "maxLength": 80 },
        "behaviorProfile": { "enum": ["makko", "mio", "posty", "saeta"] },
        "thumbnail": { "type": "string", "pattern": "^[^:\\\\]+\\.(png|webp)$" }
      }
    },
    {
      "oneOf": [
        {
          "properties": {
            "renderer": { "const": "sprite-2d" },
            "source": { "$ref": "#/$defs/sheetSource" }
          }
        },
        {
          "properties": {
            "renderer": { "const": "sprite-2d" },
            "source": { "$ref": "#/$defs/sequenceSource" }
          }
        },
        {
          "properties": {
            "renderer": { "const": "gltf-3d" },
            "source": { "$ref": "#/$defs/modelSource" }
          }
        }
      ]
    }
  ],
  "unevaluatedProperties": false,
  "$defs": {
    "motionNames": {
      "enum": ["idle", "look-around", "alert", "bounce", "self-care", "rest", "inspect", "celebrate", "walk", "deliver"]
    },
    "sheetMotion": {
      "type": "object",
      "required": ["frames", "fps"],
      "properties": {
        "frames": { "type": "array", "minItems": 1, "maxItems": 240, "items": { "type": "integer", "minimum": 0 } },
        "fps": { "type": "number", "minimum": 1, "maximum": 60 },
        "loop": { "type": "boolean", "default": true }
      },
      "additionalProperties": false
    },
    "sequenceMotion": {
      "type": "object",
      "required": ["files", "fps"],
      "properties": {
        "files": { "type": "array", "minItems": 1, "maxItems": 240, "items": { "type": "string", "pattern": "^[^:\\\\]+\\.(png|webp)$" } },
        "fps": { "type": "number", "minimum": 1, "maximum": 60 },
        "loop": { "type": "boolean", "default": true }
      },
      "additionalProperties": false
    },
    "gltfMotion": {
      "type": "object",
      "required": ["clip"],
      "properties": {
        "clip": { "type": "string", "minLength": 1, "maxLength": 80 },
        "loop": { "type": "boolean", "default": true }
      },
      "additionalProperties": false
    },
    "sheetSource": {
      "type": "object",
      "required": ["type", "file", "frameWidth", "frameHeight", "columns", "motions"],
      "properties": {
        "type": { "const": "sheet" },
        "file": { "type": "string", "pattern": "^[^:\\\\]+\\.(png|webp)$" },
        "frameWidth": { "type": "integer", "minimum": 16, "maximum": 2048 },
        "frameHeight": { "type": "integer", "minimum": 16, "maximum": 2048 },
        "columns": { "type": "integer", "minimum": 1, "maximum": 64 },
        "rows": { "type": "integer", "minimum": 1, "maximum": 64 },
        "imageRendering": { "enum": ["auto", "pixelated"] },
        "motions": {
          "type": "object",
          "required": ["idle"],
          "propertyNames": { "$ref": "#/$defs/motionNames" },
          "additionalProperties": { "$ref": "#/$defs/sheetMotion" }
        }
      },
      "additionalProperties": false
    },
    "sequenceSource": {
      "type": "object",
      "required": ["type", "motions"],
      "properties": {
        "type": { "const": "sequence" },
        "motions": {
          "type": "object",
          "required": ["idle"],
          "propertyNames": { "$ref": "#/$defs/motionNames" },
          "additionalProperties": { "$ref": "#/$defs/sequenceMotion" }
        }
      },
      "additionalProperties": false
    },
    "modelSource": {
      "type": "object",
      "required": ["type", "file", "motions"],
      "properties": {
        "type": { "const": "model" },
        "file": { "type": "string", "pattern": "^[^:\\\\]+\\.glb$" },
        "scale": { "type": "number", "minimum": 0.1, "maximum": 10, "default": 1 },
        "groundOffset": { "type": "number", "minimum": -5, "maximum": 5, "default": 0 },
        "rotationY": { "type": "number", "minimum": -360, "maximum": 360, "default": 0 },
        "motions": {
          "type": "object",
          "if": { "minProperties": 1 },
          "then": { "required": ["idle"] },
          "propertyNames": { "$ref": "#/$defs/motionNames" },
          "additionalProperties": { "$ref": "#/$defs/gltfMotion" }
        }
      },
      "additionalProperties": false
    }
  }
}
